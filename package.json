{
    "name": "packsmith",
    "type": "module",
    "private": true,
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "build": "nuxt build",
        "dev": "concurrently \"pnpm run dev:db\" \"nuxt dev\"",
        "dev:db": "turso dev --db-file local.db",
        "db:seed": "tsx server/lib/db/seed.ts",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "nuxt typecheck"
    },
    "dependencies": {
        "@iconify-json/lucide": "^1.2.98",
        "@iconify-json/simple-icons": "^1.2.74",
        "@libsql/client": "^0.17.2",
        "@nuxt/ui": "^4.6.0",
        "@tanstack/table-core": "^8.21.3",
        "@vueuse/core": "^14.2.1",
        "adm-zip": "^0.5.17",
        "better-auth": "^1.5.6",
        "concurrently": "^9.2.1",
        "drizzle-orm": "^0.45.1",
        "drizzle-zod": "^0.8.3",
        "moment": "^2.30.1",
        "nuxt": "^4.4.2",
        "semver": "^7.7.4",
        "tailwindcss": "^4.2.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^7.7.3",
        "@nuxt/eslint": "^1.15.2",
        "@types/adm-zip": "^0.5.8",
        "@types/semver": "^7.7.1",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.0.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vue-tsc": "^3.2.5"
    }
}
